        "function": "deriveVerificationWord",
        "seed": "seed_1",
        "counter": 100,
        "expected": "iron"
      },
      {
        "id": "G-05",
        "function": "deriveVerificationPhrase",
        "seed": "seed_1",
        "counter": 0,
        "wordCount": 2,
        "expected": ["situate", "airport"]
      },
      {
        "id": "G-06",
        "function": "deriveVerificationPhrase",
        "seed": "seed_1",
        "counter": 0,
        "wordCount": 3,
        "expected": ["situate", "airport", "defy"]
      },
      {
        "id": "G-07",
        "function": "deriveDuressWord",
        "seed": "seed_1",
        "pubkey": "pubkey_a",
        "counter": 0,
        "expected": "image"
      },
      {
        "id": "G-08",
        "function": "deriveDuressWord",
        "seed": "seed_1",
        "pubkey": "pubkey_b",
        "counter": 0,
        "expected": "follow"
      },
      {
        "id": "G-09",
        "function": "verifyWord",
        "seed": "seed_1",
        "members": ["pubkey_a", "pubkey_b"],
        "counter": 0,
        "input": "situate",
        "expected": { "status": "verified" }
      },
      {
        "id": "G-10",
        "function": "verifyWord",
        "seed": "seed_1",
        "members": ["pubkey_a", "pubkey_b"],
        "counter": 0,
        "input": "image",
        "expected": { "status": "duress", "members": ["pubkey_a"] }
      },
      {
        "id": "G-11",
        "function": "deriveVerificationWord",
        "seed": "seed_1",
        "counter": 4294967295,
        "expected": "oxygen"
      },
      {
        "id": "G-12",
        "function": "deriveDuressWord",
        "seed": "seed_1",
        "pubkey": "pubkey_a",
        "counter": 1136,
        "notes": "Collision: raw duress = produce = verification word at counter 1138, suffix applied",
        "expected": "ivory"
      },
      {
        "id": "G-13",
        "function": "verifyWord",
        "seed": "seed_1",
        "members": ["pubkey_a"],
        "counter": 0,
        "input": "loom",
        "notes": "loom is verification word for counter 1; stale at counter 0 with tolerance 1",
        "expected": { "status": "stale" }
      },
      {
        "id": "G-14",
        "function": "verifyWord",
        "seed": "seed_1",
